{
  "model": "haiku",
  "theme": "dark",
  "permissions": {
    "allow": ["Edit(*)", "Write(*)", "Bash(go build:*)", "Bash(go test:*)"]
  },
  "enabledPlugins": {
    "atlassian@radicle-marketplace": true
  },
  "extraKnownMarketplaces": {
    "radicle-marketplace": {
      "source": {
        "source": "git",
        "url": "git@github.com:footholdtech/claude-plugins.git"
      }
    }
  },
  "theme": "dark",
  "sandbox": {
    "filesystem": {
      "allowWrite": ["~/.cache/go-build/**", "~/go/pkg/mod/**"]
    }
  }
}
