{
  "permissions": {
    "allow": [
      "Read(*)"
      "Edit(*)",
      "Write(*)",
      "Bash(go build:*)",
      "Bash(go test:*)"
    ]
  },
  "model": "sonnet",
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "atlassian@radicle-marketplace": true
  },
  "extraKnownMarketplaces": {
    "radicle-marketplace": {
      "source": {
        "source": "git",
        "url": "git@github.com:footholdtech/claude-plugins.git"
      }
    }
  },
  "sandbox": {
    "filesystem": {
      "allowWrite": [
        "~/.cache/go-build/**",
        "~/go/pkg/mod/**"
      ]
    }
  },
  "theme": "dark"
}
