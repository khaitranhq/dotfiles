{
  "wcgw": {
    "name": "wcgw",
    "command": "uvx",
    "args": ["wcgw@latest", "--shell", "/bin/bash"],
    "enabledForAgents": [
      "Engineer",
      "PromptMaker",
      "RequirementsAnalysisSpecialist",
      "TaskPlanner",
      "DocumentationAgent",
      "DeepResearchAgent",
      "RepoAnalyzer",
      "DevOpsEngineer"
    ]
  },
  "awslabs": {
    "name": "awslabs",
    "command": "uvx",
    "args": ["awslabs.aws-api-mcp-server@latest"],
    "enabledForAgents": ["DevOpsEngineer"]
  },
  "serena": {
    "name": "serena",
    "command": "uvx",
    "args": [
      "--from",
      "git+https://github.com/oraios/serena",
      "serena",
      "start-mcp-server"
    ],
    "enabledForAgents": [
      "SerenaEngineerAgent",
      "SerenaRequirementsAnalysisSpecialist"
    ]
  },
  "pulumi": {
    "name": "pulumi",
    "command": "npx",
    "args": ["@pulumi/mcp-server", "stdio"],
    "enabledForAgents": ["SerenaEngineerAgent"]
  }
}
