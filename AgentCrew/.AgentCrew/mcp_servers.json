{
  "aws-api": {
    "name": "aws-api",
    "command": "uvx",
    "args": [
      "awslabs.aws-api-mcp-server@latest"
    ],
    "enabledForAgents": [
      "DevOpsEngineer"
    ]
  },
  "aws-cost": {
    "name": "aws-cost",
    "command": "uvx",
    "args": [
      "awslabs.aws-pricing-mcp-server@latest"
    ],
    "env": {
      "AWS_PROFILE": "default"
    },
    "enabledForAgents": [
      "DevOpsEngineer"
    ]
  },
  "serena": {
    "name": "serena",
    "command": "uvx",
    "args": [
      "--from",
      "git+https://github.com/oraios/serena",
      "serena",
      "start-mcp-server"
    ],
    "enabledForAgents": [
      "PulumiEngineer",
      "SerenaEngineerAgent",
      "SerenaRequirementsAnalysisSpecialist"
    ]
  },
  "pulumi": {
    "name": "pulumi",
    "command": "npx",
    "args": [
      "@pulumi/mcp-server",
      "stdio"
    ],
    "enabledForAgents": [
      "SerenaEngineerAgent",
      "PulumiEngineer"
    ]
  },
  "new_server_5": {
    "name": "azure",
    "command": "npx",
    "args": [
      "-y",
      "@azure/mcp@latest",
      "server",
      "start"
    ],
    "env": {},
    "enabledForAgents": [
      "DevOpsEngineer"
    ],
    "streaming_server": false,
    "url": "",
    "headers": {}
  },
  "new_server_6": {
    "name": "gopls",
    "command": "gopls",
    "args": [
      "mcp"
    ],
    "env": {},
    "enabledForAgents": [
      "PulumiEngineer"
    ],
    "streaming_server": false,
    "url": "",
    "headers": {}
  }
}
