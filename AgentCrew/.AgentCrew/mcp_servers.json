{
  "aws-api": {
    "name": "aws-api",
    "command": "uvx",
    "args": [
      "awslabs.aws-api-mcp-server@latest"
    ],
    "enabledForAgents": [
      "DevOpsEngineer",
      "PulumiEngineer"
    ]
  },
  "aws-document": {
    "name": "aws-document",
    "command": "uvx",
    "args": [
      "awslabs.aws-documentation-mcp-server@latest"
    ],
    "enabledForAgents": [
      "DevOpsEngineer",
      "PulumiEngineer",
      "SerenaEngineerAgent",
      "Engineer"
    ]
  },
  "aws-cost": {
    "name": "aws-cost",
    "command": "uvx",
    "args": [
      "awslabs.aws-pricing-mcp-server@latest"
    ],
    "env": {
      "AWS_PROFILE": "default"
    },
    "enabledForAgents": [
      "DevOpsEngineer"
    ]
  },
  "serena": {
    "name": "serena",
    "command": "uvx",
    "args": [
      "--from",
      "git+https://github.com/oraios/serena",
      "serena",
      "start-mcp-server"
    ],
    "env": {},
    "enabledForAgents": [
      "Engineer",
      "SerenaEngineerAgent",
      "SerenaRequirementsAnalysisSpecialist",
      "PulumiEngineer"
    ],
    "streaming_server": false,
    "url": "",
    "headers": {}
  },
  "pulumi": {
    "name": "pulumi",
    "command": "npx",
    "args": [
      "@pulumi/mcp-server",
      "stdio"
    ],
    "enabledForAgents": [
      "SerenaEngineerAgent",
      "PulumiEngineer"
    ]
  },
  "new_server_5": {
    "name": "azure",
    "command": "npx",
    "args": [
      "-y",
      "@azure/mcp@latest",
      "server",
      "start"
    ],
    "env": {},
    "enabledForAgents": [
      "DevOpsEngineer"
    ],
    "streaming_server": false,
    "url": "",
    "headers": {}
  },
  "new_server_7": {
    "name": "git",
    "command": "uvx",
    "args": [
      "mcp-server-git"
    ],
    "env": {},
    "enabledForAgents": [
      "Engineer",
      "RepoAnalyzer",
      "BashAgent",
      "DevOpsEngineer",
      "SerenaEngineerAgent",
      "PulumiEngineer"
    ],
    "streaming_server": false,
    "url": "",
    "headers": {}
  },
  "new_server_8": {
    "name": "go",
    "command": "gopls",
    "args": [
      "mcp"
    ],
    "env": {},
    "enabledForAgents": [
      "Engineer",
      "PulumiEngineer"
    ],
    "streaming_server": false,
    "url": "",
    "headers": {}
  }
}