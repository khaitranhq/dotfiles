{
  "aws-api": {
    "args": [
      "awslabs.aws-api-mcp-server@latest"
    ],
    "command": "uvx",
    "enabledForAgents": [
      "DevOpsEngineer",
      "PulumiEngineer"
    ],
    "name": "aws-api"
  },
  "aws-document": {
    "args": [
      "awslabs.aws-documentation-mcp-server@latest"
    ],
    "command": "uvx",
    "enabledForAgents": [
      "DevOpsEngineer",
      "PulumiEngineer",
      "SerenaEngineerAgent",
      "Engineer"
    ],
    "name": "aws-document"
  },
  "aws-cost": {
    "args": [
      "awslabs.aws-pricing-mcp-server@latest"
    ],
    "command": "uvx",
    "enabledForAgents": [
      "DevOpsEngineer"
    ],
    "env": {
      "AWS_PROFILE": "default"
    },
    "name": "aws-cost"
  },
  "serena": {
    "args": [
      "--from",
      "git+https://github.com/oraios/serena",
      "serena",
      "start-mcp-server"
    ],
    "command": "uvx",
    "enabledForAgents": [
      "Engineer",
      "SerenaEngineerAgent",
      "SerenaRequirementsAnalysisSpecialist",
      "PulumiEngineer"
    ],
    "env": {},
    "headers": {},
    "name": "serena",
    "streaming_server": false,
    "url": ""
  },
  "pulumi": {
    "args": [
      "@pulumi/mcp-server",
      "stdio"
    ],
    "command": "npx",
    "enabledForAgents": [
      "SerenaEngineerAgent",
      "PulumiEngineer"
    ],
    "name": "pulumi"
  },
  "new_server_5": {
    "args": [
      "-y",
      "@azure/mcp@latest",
      "server",
      "start"
    ],
    "command": "npx",
    "enabledForAgents": [
      "DevOpsEngineer"
    ],
    "env": {},
    "headers": {},
    "name": "azure",
    "streaming_server": false,
    "url": ""
  },
  "new_server_7": {
    "args": [
      "mcp-server-git"
    ],
    "command": "uvx",
    "enabledForAgents": [
      "Engineer",
      "RepoAnalyzer",
      "BashAgent",
      "DevOpsEngineer",
      "SerenaEngineerAgent",
      "PulumiEngineer"
    ],
    "env": {},
    "headers": {},
    "name": "git",
    "streaming_server": false,
    "url": ""
  },
  "new_server_8": {
    "args": [
      "mcp"
    ],
    "command": "gopls",
    "enabledForAgents": [
      "Engineer",
      "PulumiEngineer"
    ],
    "env": {},
    "headers": {},
    "name": "go",
    "streaming_server": false,
    "url": ""
  },
  "new_server_9": {
    "args": [
      "run",
      "-i",
      "--rm"
    ],
    "command": "docker",
    "enabledForAgents": [
      "Engineer"
    ],
    "env": {},
    "headers": {},
    "name": "mermiad",
    "streaming_server": true,
    "url": "https://mcp.mermaidchart.com/mcp"
  }
}