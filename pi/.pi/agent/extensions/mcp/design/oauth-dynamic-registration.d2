shape: sequence_diagram

pi: pi
store: Auth Store (~/.pi/agent/mcp/)
provider: OAuth Provider
oauth: OAuth Authorization Server
remote: MCP Server (Resource)
browser: Browser
callback: Callback

Initial Connect (Discovery): {
  pi.note: No clientId config
  provider."OAuth 2.1 client abstraction — handles dynamic client registration, \ntoken exchange (auth code → access/refresh), token storage, and \nsilent refresh when tokens expire. Bridges pi ↔ OAuth server ↔ MCP server."
  pi -> callback: start HTTP server
  pi."Callback HTTP server must be running\nbefore creating the provider — the\nconstructor captures redirect_uri\nfrom the active callback port/path."
  pi -> provider: new McpOAuthProvider
  pi -> remote: connect(authProvider)

  remote -> pi: 401UnauthorizedError\n(authorizationUrl, tokenUrl, registrationUrl)
  pi."401 reveals OAuth metadata.\n\nThis 401 is NOT a failure — it is the MCP\nOAuth discovery protocol (RFC 8414 style).\n\nThe same provider instance handles\ndiscovery, registration, and authorization\n— no re-creation needed."
}

Registration + Authorization: {
  Registration: {
    pi -> provider: setMetadata(metadata)

    provider."RFC 7591 registration includes\nredirect_uris (the callback URL)\nso the OAuth server can validate\nredirects after user auth."
    provider -> oauth: POST register client (RFC 7591)
    oauth -> provider: clientId + clientSecret
    provider -> store: save clientInfo
  }

  Authorization Request: {
    provider -> provider: build authorization URL\n(endpoint + clientId + redirectUri + codeChallenge + state + scope)
    provider."state = CSRF token.\nSaved to store for callback validation."
    provider -> store: save state
    provider -> pi: onRedirect(url)
    pi -> browser: open(url)
  }
}

group3: Browser Auth {
  browser -> oauth: user authenticates + approves scopes
  oauth -> browser: 302 redirect to callback?code=xxx&state=yyy
  browser -> callback: GET callback?code=xxx&state=yyy
  callback -> store: get state (saved in group2)
  callback -> callback: validate CSRF state
  pi -> pi: receive callback(code)
}

group4: Exchange + Connect {
  pi -> pi: finishAuth(code)
  pi -> provider: finishAuth(code)
  provider -> oauth: POST /token (auth code → tokens)
  oauth -> provider: accessToken + refreshToken
  provider -> store: saveTokens

  pi -> remote: reconnect (Bearer token)
  remote -> pi: 200 OK connected
  pi -> pi: state = connected
}

group5: Token Refresh {
  pi -> remote: tools/list (Bearer expired)
  remote -> pi: 401 Unauthorized

  pi -> provider: tokens()
  provider.note: Lookup by server identifier\nand resource endpoint URL.
  provider -> store: getForUrl(serverName, resourceUrl)
  store -> provider: expired accessToken + refreshToken
  provider -> pi: tokens expired

  pi -> provider: refresh
  provider -> oauth: POST /token (refresh_token grant)
  oauth -> provider: new accessToken + refreshToken
  provider -> store: saveTokens

  pi -> remote: retry (new Bearer)
  remote -> pi: tool definitions
}
