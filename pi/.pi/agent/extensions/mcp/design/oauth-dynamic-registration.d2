shape: sequence_diagram

pi: pi
client: MCP Client\n(McpClientManager)
store: Auth Store\n(~/.pi/agent/mcp/)
provider: OAuth Provider\n(McpOAuthProvider)
oauth: OAuth Authorization Server
remote: MCP Server (Resource)
browser: Browser
callback: Callback Server

Initial Connect \u0026 Discovery: {
  pi -> client: connectAll()
  client.note: Iterates configured servers at session_start — handles all MCP protocol and OAuth automatically.
  provider."OAuth 2.1 client abstraction — handles dynamic client registration, \ntoken exchange (auth code → access/refresh), token storage, and \nsilent refresh when tokens expire. Bridges client ↔ OAuth server ↔ store."
  client -> remote: initialize request (no auth)
  remote -> client: 401 Unauthorized\nWWW-Authenticate: Bearer resource_metadata="..."
  client."401 is not a failure — it is the MCP OAuth\ndiscovery protocol (RFC 9728). Triggers\nautomatic OAuth flow."
  client -> provider: discoverFrom401(wwwAuthHeader)
  provider -> oauth: fetch resource metadata (RFC 9728)\n+ authorization server metadata (RFC 8414)
  oauth -> provider: authorizationUrl + tokenUrl +\nregistrationUrl
}

Registration: {
  client -> callback: start HTTP server (random port)
  callback -> client: redirect_uri
  provider."RFC 7591 registration includes\nredirect_uris (the callback URL)\nso the OAuth server can validate\nredirects after user auth."
  provider -> oauth: POST register client (RFC 7591)\nredirect_uris, grant_types, ...
  oauth -> provider: clientId + clientSecret
  provider -> store: save clientInfo\n(serverName, resourceUrl, clientId, clientSecret)
}

Authorization Request: {
  client -> provider: buildAuthorizationUrl(scopes)
  provider -> provider: build URL (PKCE S256 +\nCSRF state + resource indicator RFC 8707)
  provider."state = CSRF token.\nSaved to store for callback validation."
  provider -> store: save state
  provider -> client: authorization URL
  client -> browser: open(url)
}

Browser Auth: {
  browser -> oauth: user authenticates + approves scopes
  oauth -> browser: 302 redirect to callback?code=xxx&state=yyy
  browser -> callback: GET /callback?code=xxx&state=yyy
  callback -> store: get state (saved in Authorization Request)
  callback -> callback: validate CSRF state
  callback -> client: resolve callback (code, state)
}

Token Exchange \u0026 Connect: {
  client -> provider: validateState(state)
  client -> provider: exchangeCode(code)
  provider -> oauth: POST /token\n(authorization_code + code_verifier + resource)
  oauth -> provider: accessToken + refreshToken
  provider -> store: save tokens\n(accessToken, refreshToken, expiresAt)
  provider -> client: TokenSet
  client -> remote: reconnect (Bearer token)
  remote -> client: 200 OK (connected) — tool definitions
  client -> pi: tools registered (mcp_ prefix)
}

Token Refresh: {
  client -> remote: tools/list (Bearer expired)
  remote -> client: 401 Unauthorized
  client -> provider: getAccessToken()
  provider -> store: get(serverName, resourceUrl)
  store -> provider: expired accessToken + refreshToken
  provider -> provider: expired → trigger refresh
  provider -> oauth: POST /token (refresh_token grant)
  oauth -> provider: new accessToken + refreshToken (rotated)
  provider -> store: save tokens
  provider -> client: new accessToken
  client -> remote: retry (new Bearer)
  remote -> client: tool result
  pi <- client: result
}
