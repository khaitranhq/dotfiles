{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "console_title_template": "{{ .Shell }} in {{ .Folder }}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "properties": {
            "cache_duration": "none"
          },
          "trailing_diamond": "\ue0b0",
          "template": "<transparent,#bb9af7>\ue0b0</> {{ .UserName }} ",
          "foreground": "#1a1b26",
          "background": "#bb9af7",
          "type": "session",
          "style": "diamond"
        },
        {
          "properties": {
            "cache_duration": "none",
            "folder_separator_icon": " \ue0b1 ",
            "home_icon": "~",
            "style": "folder"
          },
          "template": " \uea83  {{ .Path }} ",
          "foreground": "#1a1b26",
          "powerline_symbol": "\ue0b0",
          "background": "#7aa2f7",
          "type": "path",
          "style": "powerline"
        },
        {
          "properties": {
            "branch_max_length": 25,
            "cache_duration": "none",
            "fetch_stash_count": true,
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b4",
          "template": " {{ .UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} ",
          "foreground": "#1a1b26",
          "powerline_symbol": "\ue0b0",
          "background": "#e0af68",
          "type": "git",
          "style": "powerline",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#ff9e64{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#f7768e{{ end }}",
            "{{ if gt .Ahead 0 }}#9ece6a{{ end }}",
            "{{ if gt .Behind 0 }}#7dcfff{{ end }}"
          ]
        },
        {
          "properties": {
            "cache_duration": "none",
            "fetch_version": true
          },
          "template": " \ue718 {{ if .PackageManagerIcon }}{{ .PackageManagerIcon }} {{ end }}{{ .Full }} ",
          "foreground": "#1a1b26",
          "powerline_symbol": "\ue0b0",
          "background": "#9ece6a",
          "type": "node",
          "style": "powerline"
        },
        {
          "properties": {
            "cache_duration": "none",
            "fetch_version": true
          },
          "template": " \ue626 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "foreground": "#1a1b26",
          "powerline_symbol": "\ue0b0",
          "background": "#7dcfff",
          "type": "go",
          "style": "powerline"
        },
        {
          "properties": {
            "cache_duration": "none",
            "display_mode": "files",
            "fetch_virtual_env": false
          },
          "template": " \ue235 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "foreground": "#1a1b26",
          "powerline_symbol": "\ue0b0",
          "background": "#e0af68",
          "type": "python",
          "style": "powerline"
        },
        {
          "properties": {
            "cache_duration": "none",
            "display_default": false
          },
          "template": "  {{ .Profile }}{{ if .Region }}@{{ .Region }}{{ end }} ",
          "foreground": "#1a1b26",
          "powerline_symbol": "\ue0b0",
          "type": "aws",
          "style": "powerline",
          "background": "#ff9e64"
        },
        {
          "type": "pulumi",
          "style": "diamond",
          "powerline_symbol": "\ue0b0",
          "foreground": "#ffffff",
          "background": "#662d91",
          "template": "{{ .Stack }}{{if .User }} :: {{ .User }}@{{ end }}{{ if .URL }}{{ .URL }}{{ end }}"
        },
        {
          "properties": {
            "cache_duration": "none"
          },
          "template": " \uf0ad ",
          "foreground": "#1a1b26",
          "powerline_symbol": "\ue0b0",
          "background": "#e0af68",
          "type": "root",
          "style": "powerline"
        },
        {
          "properties": {
            "always_enabled": true,
            "cache_duration": "none"
          },
          "template": " \ueba2 {{ .FormattedMs }}",
          "trailing_diamond": "\ue0b0",
          "foreground": "#c0caf5",
          "background": "#414868",
          "type": "executiontime",
          "style": "diamond"
        }
      ]
    },
    {
      "type": "rprompt",
      "segments": [
        {
          "properties": {
            "cache_duration": "none"
          },
          "template": "<#7aa2f7,transparent>\ue0b2</> \uf120 {{ .Name }} <transparent,#7aa2f7>\ue0b2</>",
          "foreground": "#1a1b26",
          "background": "#7aa2f7",
          "type": "shell",
          "style": "plain"
        }
      ]
    },
    {
      "type": "prompt",
      "newline": true,
      "alignment": "left",
      "segments": [
        {
          "foreground": "#7aa2f7",
          "foreground_templates": ["{{ if gt .Code 0 }}#f7768e{{ end }}"],
          "properties": {
            "always_enabled": true
          },
          "style": "plain",
          "template": "\u276f",
          "type": "status"
        }
      ]
    }
  ],
  "version": 3,
  "final_space": true
}
