{
  "image": "devcontainer-local:latest",
  "runArgs": ["--name", "container-name"],
  "mounts": [
    "source=${localEnv:HOME}/dotfiles/nvim/.config/nvim,target=/home/ktran/.config/nvim,type=bind,consistency=cached",
    "source=${localEnv:HOME}/dotfiles/devcontainer/fish/.config/fish,target=/home/ktran/.config/fish,type=bind,consistency=cached",
    "source=${localEnv:HOME}/dotfiles/ohmyposh/.config/ohmyposh,target=/home/ktran/.config/ohmyposh,type=bind,consistency=cached",
    "source=${localEnv:HOME}/dotfiles/golangci-lint/.golangci.yaml,target=/home/ktran/.golangci.yaml,type=bind,consistency=cached",
    "source=${localEnv:HOME}/dotfiles/eza/.config/eza,target=/home/ktran/.config/eza,type=bind,consistency=cached",
    "source=${localEnv:HOME}/dotfiles/lazygit/.config/lazygit,target=/home/ktran/.config/lazygit,type=bind,consistency=cached",
    "source=${localEnv:HOME}/dotfiles/opencode/.config/opencode,target=/home/ktran/.config/opencode,type=bind,consistency=cached"
  ],
  "features": {
    "ghcr.io/khaitranhq/devcontainer-features/go:1.1.3": {
      "version": "1.25.7",
      "packages": "github.com/golangci/golines@v0.15.0,mvdan.cc/gofumpt@v0.9.2,golang.org/x/tools/cmd/goimports@v0.42.0,golang.org/x/tools/gopls@v0.21.1"
    },
    "ghcr.io/khaitranhq/devcontainer-features/golangci-lint:1.0.0": {
      "version": "2.10.1"
    }
  },
  "remoteUser": "ktran"
}
