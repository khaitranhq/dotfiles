{
  "buffer_font_family": "FiraCode Nerd Font Mono",
  "agent": {
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-4.1",
      "enable_thinking": false
    },
    "favorite_models": [],
    "model_parameters": []
  },
  "terminal": {
    "dock": "right"
  },
  "vim_mode": true,
  "ui_font_size": 16,
  "relative_line_numbers": "enabled",
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Tokyo Night Storm"
  },
  "edit_predictions": {
    "mode": "eager",
    "disabled_globs": ["**/node_modules"],
    "provider": "copilot"
  },
  "format_on_save": "on",
  "lsp": {
    "golangci-lint": {
      "initialization_options": {
        "command": [
          "golangci-lint",
          "run",
          "--config=~/.golangci.yaml",
          "--output.json.path",
          "stdout",
          "--show-stats=false",
          "--output.text.path="
        ]
      }
    },
    "marksman": {
      "initialization_options": {}
    }
  },
  "languages": {
    "Go": {
      "language_servers": ["gopls", "golangci-lint"]
    },
    "Markdown": {
      "language_servers": ["marksman"]
    }
  }
}
