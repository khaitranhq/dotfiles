[
  {
    "context": "Workspace",
    "bindings": {
      "alt-h": ["workspace::ActivatePaneInDirection", "Left"],
      "alt-l": ["workspace::ActivatePaneInDirection", "Right"],
      "alt-j": ["workspace::ActivatePaneInDirection", "Down"],
      "alt-k": ["workspace::ActivatePaneInDirection", "Up"],
      "alt-p l": "workspace::ToggleLeftDock",
      "alt-p r": "workspace::ToggleRightDock"
    }
  },
  {
    "context": "vim_mode == normal",
    "bindings": {
      ";": "command_palette::Toggle"
    }
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {}
  },
  {
    "context": "((os != macos && Editor) && edit_prediction_conflict)",
    "bindings": {
      "alt-l": null
    }
  },
  {
    "context": "(Editor && edit_prediction_conflict)",
    "bindings": {
      "tab": null,
      "alt-l": null,
      "alt-tab": null,
      "alt-o": "editor::AcceptEditPrediction"
    }
  },
  {
    "context": "(Editor && edit_prediction)",
    "bindings": {
      "tab": "editor::Tab",
      "alt-l": null,
      "alt-tab": null,
      "alt-o": "editor::AcceptEditPrediction"
    }
  }
]
