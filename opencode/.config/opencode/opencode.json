{
  "$schema": "https://opencode.ai/config.json",
  "theme": "tokyonight",
  "permission": {
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "find *": "allow",
      "grep *": "allow",
      "go build *": "allow",
      "go doc *": "allow",
      "go version*": "allow",
      "go vet*": "allow",
      "which *": "allow",
      "wc *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "echo *": "allow",
      "pwd": "allow",
      "rg *": "allow",
      "xargs *": "allow",
      "git log *": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "git branch*": "allow",
      "pulumi preview *": "allow",
      "pulumi stack ls*": "allow",
      "golangci-lint run*": "allow"
    }
  },
  "agent": {
    "Architect": {
      "mode": "primary",
      "prompt": "{file:/home/lewis/.config/opencode/agents/Architect.md}"
    },
    "Planner": {
      "mode": "primary",
      "model": "github-copilot/claude-sonnet-4.5",
      "prompt": "{file:/home/lewis/.config/opencode/agents/Planner.md}"
    },
    "DevOps": {
      "mode": "primary",
      "prompt": "{file:/home/lewis/.config/opencode/agents/DevOps.md}"
    },
    "GitGenerator": {
      "mode": "primary",
      "model": "github-copilot/gpt-5-mini",
      "prompt": "{file:/home/lewis/.config/opencode/agents/GitGenerator.md}"
    },
    "Coordinator": {
      "mode": "primary",
      "prompt": "{file:/home/lewis/.config/opencode/agents/Coordinator.md}"
    },
    "CodeReviewer": {
      "mode": "primary",
      "prompt": "{file:/home/lewis/.config/opencode/agents/CodeReviewer.md}",
      "permission": {
        "todowrite": "allow",
        "todoread": "allow"
      }
    },
    "Engineer": {
      "mode": "primary",
      "prompt": "{file:/home/lewis/.config/opencode/agents/Engineer.md}",
      "permission": {
        "todowrite": "allow",
        "todoread": "allow"
      }
    },
    "plan": {
      "disable": true
    }
  }
}
