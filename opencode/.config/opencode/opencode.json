{
  "$schema": "https://opencode.ai/config.json",
  "theme": "tokyonight",
  "permission": {
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "find *": "allow",
      "grep *": "allow",
      "go build *": "allow",
      "go doc *": "allow",
      "go version*": "allow",
      "go vet *": "allow",
      "go test *": "allow",
      "gofmt *": "allow",
      "golangci-lint *": "allow",
      "go mod *": "allow",
      "staticcheck *": "allow",
      "gosec *": "allow",
      "which *": "allow",
      "wc *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "echo *": "allow",
      "pwd": "allow",
      "rg *": "allow",
      "xargs *": "allow",
      "git log *": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "git branch*": "allow",
      "pulumi preview *": "allow",
      "pulumi stack ls*": "allow",
      "tee *": "allow",
      "awk *": "allow",
      "mkdir *": "allow",
      "mmdc *": "allow",
      "sed -n *": "allow",
      "test -f *": "allow",
      "test -d *": "allow"
    },
    "external_directory": {
      "*": "ask",
      "~/dotfiles/opencode/.config/opencode/**/*": "allow",
      "~/go/pkg/mod": "allow"
    }
  },
  "tools": {
    "aws-pricing*": false
  },
  "agent": {
    "GitGenerator": {
      "mode": "primary",
      "model": "github-copilot/gpt-5-mini",
      "prompt": "{file:agents/GitGenerator.md}"
    },
    "RequirementsAgent": {
      "mode": "subagent",
      "prompt": "{file:agents/RequirementsAgent.md}",
      "permission": {
        "todowrite": "allow",
        "todoread": "allow",
        "question": "allow"
      }
    },
    "ArchitectAgent": {
      "mode": "subagent",
      "prompt": "{file:agents/ArchitectAgent.md}",
      "permission": {
        "todowrite": "allow",
        "todoread": "allow",
        "question": "allow"
      },
      "tools": {
        "aws-pricing*": true
      }
    },
    "PlanningAgent": {
      "mode": "subagent",
      "prompt": "{file:agents/PlanningAgent.md}",
      "permission": {
        "todowrite": "allow",
        "todoread": "allow",
        "question": "allow"
      }
    },
    "CoderAgent": {
      "mode": "subagent",
      "prompt": "{file:agents/CoderAgent.md}",
      "permission": {
        "todowrite": "allow",
        "todoread": "allow",
        "question": "allow"
      }
    },
    "CodeReviewAgent": {
      "mode": "subagent",
      "prompt": "{file:agents/CodeReviewAgent.md}",
      "permission": {
        "todowrite": "allow",
        "todoread": "allow",
        "question": "allow"
      }
    },
    "ArchitectMasterAgent": {
      "mode": "primary",
      "prompt": "{file:agents/ArchitectMasterAgent.md}"
    },
    "ImplementationMasterAgent": {
      "mode": "primary",
      "prompt": "{file:agents/ImplementationMasterAgent.md}"
    },
    "plan": {
      "disable": true
    }
  },
  "mcp": {
    "aws-pricing": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/khaitranhq/mcp@fix/pricing-add-botocore-crt#subdirectory=src/aws-pricing-mcp-server",
        "awslabs.aws-pricing-mcp-server"
      ],
      "environment": {
        "AWS_PROFILE": "default"
      }
    }
  }
}
