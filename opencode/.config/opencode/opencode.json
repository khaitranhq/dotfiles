{
  "$schema": "https://opencode.ai/config.json",
  "theme": "tokyonight",
  "permission": {
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "find *": "allow",
      "grep *": "allow",
      "go build *": "allow",
      "go doc *": "allow",
      "go version*": "allow",
      "go vet*": "allow",
      "go test*": "allow",
      "go fmt*": "allow",
      "golangci-lint run*": "allow",
      "which *": "allow",
      "wc *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "echo *": "allow",
      "pwd": "allow",
      "rg *": "allow",
      "xargs *": "allow",
      "git log *": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "git branch*": "allow",
      "pulumi preview *": "allow",
      "pulumi stack ls*": "allow",
      "tee *": "allow",
      "awk *": "allow",
      "mkdir *": "allow",
      "mmdc *": "allow",
      "sed -n *": "allow",
      "test -f *": "allow",
      "test -d *": "allow"
    },
    "external_directory": {
      "*": "ask",
      "~/.config/opencode/skills": "allow",
      "~/dotfiles/opencode/.config/opencode": "allow",
      "~/go/pkg/mod": "allow"
    }
  },
  "tools": {
    "aws-pricing*": false
  },
  "agent": {
    "GitGenerator": {
      "mode": "primary",
      "model": "github-copilot/gpt-5-mini",
      "prompt": "{file:/home/lewis/.config/opencode/agents/GitGenerator.md}"
    },
    "RequirementsAgent": {
      "mode": "subagent",
      "prompt": "{file:agents/RequirementsAgent.md}"
    },
    "ArchitectAgent": {
      "mode": "subagent",
      "prompt": "{file:agents/ArchitectAgent.md}"
    },
    "PlanningAgent": {
      "mode": "subagent",
      "prompt": "{file:agents/PlanningAgent.md}"
    },
    "ImplementationAgent": {
      "mode": "subagent",
      "prompt": "{file:agents/ImplementationAgent.md}"
    },
    "CodeReviewAgent": {
      "mode": "subagent",
      "prompt": "{file:agents/CodeReviewAgent.md}"
    },
    "SupervisorAgent": {
      "mode": "primary",
      "prompt": "{file:agents/SupervisorAgent.md}"
    },
    "plan": {
      "disable": true
    }
  },
  "mcp": {
    "aws-pricing": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/khaitranhq/mcp@fix/pricing-add-botocore-crt#subdirectory=src/aws-pricing-mcp-server",
        "awslabs.aws-pricing-mcp-server"
      ]
    }
  }
}
