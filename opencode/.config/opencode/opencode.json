{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "find *": "allow",
      "grep *": "allow",
      "go build *": "allow",
      "go doc *": "allow",
      "go list *": "allow",
      "go version*": "allow",
      "go vet *": "allow",
      "go test *": "allow",
      "gofmt *": "allow",
      "go fmt *": "allow",
      "goimports *": "allow",
      "gofumpt *": "allow",
      "golines *": "allow",
      "golangci-lint run *": "allow",
      "go mod *": "allow",
      "staticcheck *": "allow",
      "gosec *": "allow",
      "which *": "allow",
      "wc *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "echo *": "allow",
      "pwd": "allow",
      "rg *": "allow",
      "xargs *": "allow",
      "git log *": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "git branch *": "allow",
      "git rev-parse *": "allow",
      "git ls-tree *": "allow",
      "pulumi preview *": "allow",
      "pulumi stack ls*": "allow",
      "tee *": "allow",
      "awk *": "allow",
      "mkdir *": "allow",
      "mmdc *": "allow",
      "sed -n *": "allow",
      "test -f *": "allow",
      "test -d *": "allow",
      "sort": "allow",
      "sort *": "allow",
      "yamllint *": "allow",
      "d2 *": "allow",
      "actionlint *": "allow",
      "zizmor *": "allow",
      "eslint *": "allow",
      "npx eslint *": "allow",
      "prettier *": "allow",
      "npx tsc *": "allow"
    },
    "external_directory": {
      "*": "ask",
      "~/dotfiles/opencode/.config/opencode/**/*": "allow",
      "~/.config/opencode/**/*": "allow",
      "~/go/pkg/mod/**/*": "allow",
      "/tmp/*": "allow"
    }
  },
  "tools": {
    "aws-pricing*": false
  },
  "agent": {
    "git-generator": {
      "mode": "primary",
      "model": "github-copilot/gpt-4.1",
      "prompt": "{file:agents/git-generator.md}"
    },
    "requirements-analyzer": {
      "mode": "subagent",
      "prompt": "{file:agents/requirements-analyzer.md}",
      "permission": {
        "todowrite": "allow",
        "todoread": "allow",
        "question": "allow"
      }
    },
    "architect": {
      "mode": "subagent",
      "prompt": "{file:agents/architect.md}",
      "permission": {
        "todowrite": "allow",
        "todoread": "allow",
        "question": "allow"
      },
      "tools": {
        "aws-pricing*": true
      }
    },
    "planner": {
      "mode": "subagent",
      "prompt": "{file:agents/planner.md}",
      "permission": {
        "todowrite": "allow",
        "todoread": "allow",
        "question": "allow"
      }
    },
    "coder": {
      "mode": "subagent",
      "prompt": "{file:agents/coder.md}",
      "permission": {
        "todowrite": "allow",
        "todoread": "allow",
        "question": "allow"
      }
    },
    "code-reviewer": {
      "mode": "subagent",
      "prompt": "{file:agents/code-reviewer.md}",
      "permission": {
        "todowrite": "allow",
        "todoread": "allow",
        "question": "allow"
      }
    },
    "architect-orchestrator": {
      "mode": "primary",
      "prompt": "{file:agents/architect-orchestrator.md}",
      "permission": {
        "question": "allow"
      }
    },
    "development-coordinator": {
      "mode": "primary",
      "prompt": "{file:agents/development-coordinator.md}",
      "permission": {
        "question": "allow"
      }
    },
    "plan": {
      "disable": true
    }
  },
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_MCP_TOKEN}"
      }
    },
    "eraser": {
      "type": "local",
      "command": ["npx", "@eraserlabs/eraser-mcp"]
    },
    "jira": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp"
    }
  }
}
