{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@mohak34/opencode-notifier@latest"],
  "permission": {
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "find *": "allow",
      "grep *": "allow",
      "go build *": "allow",
      "go doc *": "allow",
      "go list *": "allow",
      "go version*": "allow",
      "go vet *": "allow",
      "go test *": "allow",
      "gofmt *": "allow",
      "go fmt *": "allow",
      "goimports *": "allow",
      "gofumpt *": "allow",
      "golines *": "allow",
      "golangci-lint run *": "allow",
      "go mod *": "allow",
      "staticcheck *": "allow",
      "gosec *": "allow",
      "which *": "allow",
      "wc *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "echo *": "allow",
      "pwd": "allow",
      "rg *": "allow",
      "xargs *": "allow",
      "git log *": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "git branch *": "allow",
      "git rev-parse *": "allow",
      "git ls-tree *": "allow",
      "pulumi preview *": "allow",
      "pulumi stack ls*": "allow",
      "tee *": "allow",
      "awk *": "allow",
      "mkdir *": "allow",
      "mmdc *": "allow",
      "sed -n *": "allow",
      "test -f *": "allow",
      "test -d *": "allow",
      "sort": "allow",
      "sort *": "allow",
      "yamllint *": "allow",
      "d2 *": "allow",
      "actionlint *": "allow",
      "zizmor *": "allow"
    },
    "external_directory": {
      "*": "ask",
      "~/dotfiles/opencode/.config/opencode/**/*": "allow",
      "~/.config/opencode/**/*": "allow",
      "~/go/pkg/mod/**/*": "allow",
      "/tmp/*": "allow"
    }
  },
  "tools": {
    "aws-pricing*": false
  },
  "agent": {
    "git-generator": {
      "mode": "primary",
      "model": "github-copilot/gpt-4.1",
      "prompt": "{file:agents/git-generator.md}"
    },
    "requirements-agent": {
      "mode": "subagent",
      "prompt": "{file:agents/requirements-agent.md}",
      "permission": {
        "todowrite": "allow",
        "todoread": "allow",
        "question": "allow"
      }
    },
    "architect-agent": {
      "mode": "subagent",
      "prompt": "{file:agents/architect-agent.md}",
      "permission": {
        "todowrite": "allow",
        "todoread": "allow",
        "question": "allow"
      },
      "tools": {
        "aws-pricing*": true
      }
    },
    "planning-agent": {
      "mode": "subagent",
      "prompt": "{file:agents/planning-agent.md}",
      "permission": {
        "todowrite": "allow",
        "todoread": "allow",
        "question": "allow"
      }
    },
    "coder-agent": {
      "mode": "subagent",
      "prompt": "{file:agents/coder-agent.md}",
      "permission": {
        "todowrite": "allow",
        "todoread": "allow",
        "question": "allow"
      }
    },
    "code-review-agent": {
      "mode": "subagent",
      "prompt": "{file:agents/code-review-agent.md}",
      "permission": {
        "todowrite": "allow",
        "todoread": "allow",
        "question": "allow"
      }
    },
    "architect-master-agent": {
      "mode": "primary",
      "prompt": "{file:agents/architect-master-agent.md}",
      "permission": {
        "question": "allow"
      }
    },
    "implementation-master-agent": {
      "mode": "primary",
      "prompt": "{file:agents/implementation-master-agent.md}",
      "permission": {
        "question": "allow"
      }
    },
    "plan": {
      "disable": true
    }
  },
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_MCP_TOKEN}"
      }
    }
  }
}
