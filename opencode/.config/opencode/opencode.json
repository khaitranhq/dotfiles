{
  "$schema": "https://opencode.ai/config.json",
  "theme": "tokyonight",
  "permission": {
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "find *": "allow",
      "grep *": "allow",
      "go build *": "allow",
      "go doc *": "allow",
      "go version*": "allow",
      "go vet*": "allow",
      "go test*": "allow",
      "go fmt*": "allow",
      "golangci-lint run*": "allow",
      "which *": "allow",
      "wc *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "echo *": "allow",
      "pwd": "allow",
      "rg *": "allow",
      "xargs *": "allow",
      "git log *": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "git branch*": "allow",
      "pulumi preview *": "allow",
      "pulumi stack ls*": "allow",
      "tee *": "allow",
      "aws *": "allow",
      "mkdir *": "allow",
      "mmdc *": "allow"
    }
  },
  "tools": {
    "aws-pricing*": false
  },
  "agent": {
    "Architect": {
      "mode": "primary",
      "prompt": "{file:/home/lewis/.config/opencode/agents/Architect.md}",
      "tools": {
        "aws-pricing*": true
      }
    },
    "Planner": {
      "mode": "primary",
      "model": "github-copilot/claude-sonnet-4.5",
      "prompt": "{file:/home/lewis/.config/opencode/agents/Planner.md}"
    },
    "DevOps": {
      "mode": "primary",
      "prompt": "{file:/home/lewis/.config/opencode/agents/DevOps.md}"
    },
    "GitGenerator": {
      "mode": "primary",
      "model": "github-copilot/gpt-5-mini",
      "prompt": "{file:/home/lewis/.config/opencode/agents/GitGenerator.md}"
    },
    "DevelopmentCoordinator": {
      "mode": "primary",
      "prompt": "{file:/home/lewis/.config/opencode/agents/DevelopmentCoordinator.md}"
    },
    "CodeReviewer": {
      "mode": "primary",
      "prompt": "{file:/home/lewis/.config/opencode/agents/CodeReviewer.md}",
      "permission": {
        "todowrite": "allow",
        "todoread": "allow"
      }
    },
    "Engineer": {
      "mode": "primary",
      "prompt": "{file:/home/lewis/.config/opencode/agents/Engineer.md}",
      "permission": {
        "todowrite": "allow",
        "todoread": "allow"
      }
    },
    "Documentor": {
      "mode": "primary",
      "prompt": "{file:/home/lewis/.config/opencode/agents/Documentor.md}"
    },
    "EnglishLearningAssistant": {
      "mode": "primary",
      "prompt": "{file:/home/lewis/.config/opencode/agents/EnglishLearningAssistant.md}"
    },
    "plan": {
      "disable": true
    }
  },
  "mcp": {
    "aws-pricing": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/khaitranhq/mcp@fix/pricing-add-botocore-crt#subdirectory=src/aws-pricing-mcp-server",
        "awslabs.aws-pricing-mcp-server"
      ]
    }
  }
}
