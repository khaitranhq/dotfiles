#!/usr/bin/env bash
# Save every tmux session: windows, pane layout, working directory, and
# the foreground command running in each pane.
#
# Output: ~/.local/share/tmux/sessions/last.json
# Schedule: systemd timer every 60 s (tmux-save-sessions.timer)
set -euo pipefail

SAVE_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/tmux/sessions"
SAVE_FILE="$SAVE_DIR/last.json"
TMP_FILE="$SAVE_DIR/.tmp.json"
DELIM=$'\x1f'   # ASCII Unit Separator — guaranteed not to appear in paths or command names

export PATH="$HOME/.local/bin:$PATH"

mkdir -p "$SAVE_DIR"

# Nothing to save if tmux server is not running
if ! tmux has-session 2>/dev/null; then
    exit 0
fi

# Flatten every pane into one line per pane, then nest with jq.
tmux list-panes -a -F \
    "#{session_name}${DELIM}#{window_index}${DELIM}#{window_name}${DELIM}#{window_active}${DELIM}#{window_layout}${DELIM}#{pane_index}${DELIM}#{pane_active}${DELIM}#{pane_current_path}${DELIM}#{pane_current_command}" \
| jq -Rn '

    # Helper: mark the active item in a list of panes / windows
    def flag_active:
        if any(.[]; .active == "1") then
            map(if .active == "1" then . + {active: true} else . + {active: false} end)
        else
            .
        end;

    [ inputs
        | select(length > 0)
        | split("\u001f")
        | { session:     .[0],
            win_idx:     .[1] | tonumber,
            win_name:    .[2],
            win_active:  .[3],
            win_layout:  .[4],
            pane_idx:    .[5] | tonumber,
            pane_active: .[6],
            pane_path:   .[7],
            pane_cmd:    .[8] }
    ]
    | group_by(.session)
    | map({
        session: .[0].session,
        windows: (
            group_by(.win_idx)
            | map({
                index:  .[0].win_idx,
                name:   .[0].win_name,
                active: .[0].win_active,
                layout: .[0].win_layout,
                panes: (
                    map({
                        index:   .pane_idx,
                        path:    .pane_path,
                        command: .pane_cmd,
                        active:  .pane_active
                    })
                    | flag_active
                    | sort_by(.index)
                )
            })
            | flag_active
            | sort_by(.index)
        )
    })
' > "$TMP_FILE" && mv "$TMP_FILE" "$SAVE_FILE"
