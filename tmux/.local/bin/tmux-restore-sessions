#!/usr/bin/env bash
# Restore tmux sessions from a previously saved snapshot.
#
# Reads  ~/.local/share/tmux/sessions/last.json  (produced by tmux-save-sessions).
# Skips sessions that already exist so running sessions are never overwritten.
#
# Usage:
#   tmux-restore-sessions               # restore all
#   tmux-restore-sessions --force       # overwrite existing sessions
#   tmux-restore-sessions --dry-run     # print what would be restored
#   tmux-restore-sessions --no-commands # skip restarting foreground programs
set -euo pipefail

# ---------------------------------------------------------------------------
# Dependency checks
# ---------------------------------------------------------------------------
for dep in jq tmux; do
    if ! command -v "$dep" >/dev/null 2>&1; then
        echo "tmux-restore: $dep is required but not found in PATH" >&2
        exit 1
    fi
done

# Warn if ssh-agent is not running (restore may still work, but SSH mounts
# referenced in saved paths won't be accessible in restored panes).
if [[ -z "${SSH_AUTH_SOCK:-}" ]] || [[ -z "${SSH_AGENT_PID:-}" ]]; then
    echo "tmux-restore: warning: ssh-agent not detected — SSH-mounted paths may fail to cd" >&2
fi

SAVE_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/tmux/sessions"
SAVE_FILE="$SAVE_DIR/last.json"
export PATH="$PATH:$HOME/.local/bin"

FORCE=false
DRY_RUN=false
RESTORE_COMMANDS=true

for arg in "$@"; do
    case "$arg" in
        --force)        FORCE=true ;;
        --dry-run)      DRY_RUN=true ;;
        --no-commands)  RESTORE_COMMANDS=false ;;
        *)              echo "Unknown option: $arg" >&2; exit 1 ;;
    esac
done

# ---------------------------------------------------------------------------
# Helper: decide whether a foreground command should be re-sent to the pane.
# Skip shells (they already run in every new pane) and short-lived helpers.
# ---------------------------------------------------------------------------
is_restorable_command() {
    local cmd="$1"
    case "$cmd" in
        nvim|pi) return 1 ;;
        *) return 0 ;;
    esac
}

# ---------------------------------------------------------------------------
# Escape a path so it survives a single-quoted shell string on the other side.
# ---------------------------------------------------------------------------
escape_path() {
    local p="${1//\'/\'\\\'\'}"
    printf '%s' "$p"
}

# ---------------------------------------------------------------------------
# Create additional panes in the target window, then apply the saved layout,
# then cd to the right directory in each pane (and optionally restart the
# foreground program).
# ---------------------------------------------------------------------------
setup_window() {
    local session="$1"
    local win_json="$2"

    local win_index layout pane_count target
    win_index=$(echo "$win_json"  | jq -r '.index')
    layout=$(echo "$win_json"     | jq -r '.layout')
    pane_count=$(echo "$win_json" | jq '.panes | length')
    target="$session:$win_index"

    # ---- create panes (first pane already exists from new-session / new-window) ----
    local i
    for i in $(seq 1 $((pane_count - 1))); do
        local pane_path
        pane_path=$(echo "$win_json" | jq -r ".panes[$i].path")
        if (( i % 2 == 1 )); then
            $DRY_RUN || tmux split-window -h -t "$target" -c "$pane_path"
        else
            $DRY_RUN || tmux split-window -v -t "$target" -c "$pane_path"
        fi
    done

    # ---- apply saved layout ----
    $DRY_RUN || tmux select-layout -t "$target" "$layout" 2>/dev/null || true

    # ---- send commands to each pane ----
    for i in $(seq 0 $((pane_count - 1))); do
        local pane_path pane_cmd safe_path pane_name
        pane_path=$(echo "$win_json" | jq -r ".panes[$i].path")
        pane_cmd=$(echo "$win_json"  | jq -r ".panes[$i].command")
        safe_path=$(escape_path "$pane_path")
        local pane_target="${target}.$((i + 1))"

        # Always cd to the saved working directory
        $DRY_RUN || tmux send-keys -t "$pane_target" "cd '${safe_path}'" Enter

        # Optionally restart the application that was running
        if $RESTORE_COMMANDS && is_restorable_command "$pane_cmd"; then
            $DRY_RUN || tmux send-keys -t "$pane_target" "$pane_cmd" Enter
        fi
    done

    # ---- select the previously-active pane ----
    local active_pane
    active_pane=$(echo "$win_json" | jq -r '.panes[] | select(.active == true) | .index' | head -1)
    if [[ -n "$active_pane" ]]; then
        $DRY_RUN || tmux select-pane -t "$target.$active_pane"
    fi
}

# ===========================================================================
# MAIN
# ===========================================================================

if [[ ! -f "$SAVE_FILE" ]]; then
    echo "tmux-restore: no saved state at $SAVE_FILE — nothing to do"
    exit 0
fi

session_count=$(jq '. | length' "$SAVE_FILE")
if (( session_count == 0 )); then
    echo "tmux-restore: saved state is empty — nothing to do"
    exit 0
fi

$DRY_RUN || tmux start-server

for i in $(seq 0 $((session_count - 1))); do
    session_name=$(jq -r ".[$i].session" "$SAVE_FILE")

    if tmux has-session -t "$session_name" 2>/dev/null; then
        if $FORCE; then
            echo "tmux-restore: killing existing session '$session_name' (--force)"
            $DRY_RUN || tmux kill-session -t "$session_name"
        else
            echo "tmux-restore: session '$session_name' already exists — skipping"
            continue
        fi
    fi

    windows_json=$(jq -c ".[$i].windows" "$SAVE_FILE")
    win_count=$(echo "$windows_json" | jq 'length')

    # --- first window (created together with the session) ---
    first_win=$(echo "$windows_json" | jq -c '.[0]')
    first_name=$(echo "$first_win" | jq -r '.name')
    first_path=$(echo "$first_win" | jq -r '.panes[0].path')

    if $DRY_RUN; then
        echo "[dry-run] new-session -d -s '$session_name' -n '$first_name' -c '$first_path'"
    else
        tmux new-session -d -s "$session_name" -n "$first_name" -c "$first_path"
    fi
    setup_window "$session_name" "$first_win"

    # --- remaining windows ---
    for w in $(seq 1 $((win_count - 1))); do
        win=$(echo "$windows_json" | jq -c ".[$w]")
        win_name=$(echo "$win" | jq -r '.name')
        win_path=$(echo "$win" | jq -r '.panes[0].path')

        if $DRY_RUN; then
            echo "[dry-run] new-window -t '$session_name' -n '$win_name' -c '$win_path'"
        else
            tmux new-window -t "$session_name" -n "$win_name" -c "$win_path"
        fi
        setup_window "$session_name" "$win"
    done

    # --- select the active window ---
    active_win=$(echo "$windows_json" | jq -r '.[] | select(.active == true or .active == "1") | .name' | head -1)
    if [[ -n "$active_win" ]]; then
        $DRY_RUN || tmux select-window -t "$session_name:$active_win"
    fi

    echo "tmux-restore: restored session '$session_name' ($win_count windows)"
done
