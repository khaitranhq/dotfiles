// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      ";": "command_palette::Toggle"
    }
  },
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      // https://github.com/zed-industries/zed/issues/4753
      // https://github.com/zed-industries/zed/issues/4270
      "enter": "project_panel::Open",
      "o": "project_panel::NewDirectory",
      "a": "project_panel::NewFile",
      "r": "project_panel::Rename",
      "x": "project_panel::Cut",
      "y": "project_panel::Copy",
      "p": "project_panel::Paste",
      "d": "project_panel::Delete",
      // Directory expansion
      "l": "project_panel::ExpandSelectedEntry",
      "h": "project_panel::CollapseSelectedEntry",
      // Move up and down
      "j": "menu::SelectNext",
      "k": "menu::SelectPrevious"
      // "space l": "workspace::ToggleLeftDock",
    }
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "ctrl-alt-r": "workspace::ToggleRightDock"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-alt-r": "workspace::ToggleRightDock",
      "ctrl-alt-l": "workspace::ToggleLeftDock",
      "ctrl-t": "workspace::NewFile",
      "ctrl-shift-o": "projects::OpenRecent",
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-t": "workspace::NewTerminal",
      "ctrl-n": null,
      "ctrl-p": null
    }
  },
  {
    "context": "Terminal",
    "unbind": {
      "ctrl-alt-r": "terminal::RerunTask"
    }
  },
  {
    "bindings": {
      "alt-shift-`": "workspace::NewCenterTerminal"
    }
  },
  {
    "bindings": {
      "ctrl-b": "project_panel::Toggle"
    }
  },
  {
    "context": "Editor && mode == full",
    "unbind": {
      "ctrl-shift-o": "outline::Toggle"
    }
  },
  {
    "context": "Editor && edit_prediction && edit_prediction_mode == eager && !showing_completions",
    "unbind": {
      "tab": "editor::AcceptEditPrediction"
    }
  },
  {
    "context": "Editor && edit_prediction",
    "unbind": {
      "alt-tab": "editor::AcceptEditPrediction"
    }
  },
  {
    "context": "BufferSearchBar",
    "unbind": {
      "ctrl-h": "search::ToggleReplace"
    }
  },
  {
    "context": "Editor && mode == full",
    "unbind": {
      "ctrl-h": "buffer_search::DeployReplace"
    }
  },
  {
    "context": "Editor",
    "unbind": {
      "ctrl-l": "editor::SelectLine"
    }
  },
  {
    "context": "FileFinder || FileFinder > Picker > Editor || FileFinder > Picker > menu",
    "unbind": {
      "ctrl-j": "pane::SplitDown"
    }
  },
  {
    "context": "VimControl && !menu",
    "unbind": {
      "ctrl-j": "vim::Down"
    }
  },
  {
    "context": "vim_mode == literal",
    "unbind": {
      "ctrl-j": [
        "vim::Literal",
        [
          "ctrl-j",
          "\n"
        ]
      ]
    }
  }
]
